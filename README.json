{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Bill Pay Error Monitoring — counts by error code and exception kind",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Current Window — How bad is it?",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          },
          "unit": "none",
          "noValue": "0",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "title": "Total Errors",
      "description": "Total number of errors recorded in the selected time window.",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(increase(external_billpay_errors_total{application=\"$application\"}[$__range]))",
          "legendFormat": "Total Errors",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "none",
          "noValue": "0",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "title": "Client Errors",
      "description": "Errors caused by invalid or unexpected input from callers (validation, business rule violations).",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(increase(external_billpay_errors_total{application=\"$application\",outcome=\"client_error\"}[$__range]))",
          "legendFormat": "Client Errors",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "none",
          "noValue": "0",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "title": "🔴 Server Errors",
      "description": "Errors caused by internal failures — these always need investigation.",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(increase(external_billpay_errors_total{application=\"$application\",outcome=\"server_error\"}[$__range]))",
          "legendFormat": "Server Errors",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "none",
          "noValue": "0",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "title": "🔻 Downstream Errors",
      "description": "Errors from calls made to external systems (e.g. payment processors). High counts may indicate a partner outage.",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(increase(external_billpay_downstream_errors_total{application=\"$application\"}[$__range]))",
          "legendFormat": "Downstream Errors",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 101,
      "title": "Which errors are firing?",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineWidth": 1,
            "axisPlacement": "auto",
            "axisColorMode": "text"
          },
          "unit": "none",
          "noValue": "0",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 13, "x": 0, "y": 7 },
      "id": 10,
      "options": {
        "barRadius": 0.05,
        "barWidth": 0.7,
        "fullHighlight": false,
        "groupWidth": 0.7,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "orientation": "horizontal",
        "showValue": "always",
        "stacking": "none",
        "tooltip": { "mode": "single", "sort": "desc" },
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 0
      },
      "title": "Errors by Error Code",
      "description": "Total error count per error code in the selected time window. Sorted highest to lowest.",
      "type": "barchart",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sort_desc(sum by (error_code) (increase(external_billpay_errors_total{application=\"$application\",exception_kind=~\"$exception_kind\",outcome=~\"$outcome\"}[$__range])))",
          "legendFormat": "{{error_code}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "application": true, "job": true, "instance": true, "exception_kind": true, "outcome": true },
            "renameByName": { "error_code": "Error Code", "Value": "Count" }
          }
        },
        {
          "id": "sortBy",
          "options": { "fields": [{ "desc": true, "displayName": "Count" }] }
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineWidth": 1,
            "axisPlacement": "auto",
            "axisColorMode": "text"
          },
          "unit": "none",
          "noValue": "0",
          "mappings": [
            { "type": "value", "options": { "validation": { "text": "Validation", "index": 0 } } },
            { "type": "value", "options": { "business_rule": { "text": "Business Rule", "index": 1 } } },
            { "type": "value", "options": { "downstream_error": { "text": "Downstream Error", "index": 2 } } },
            { "type": "value", "options": { "not_found": { "text": "Not Found", "index": 3 } } },
            { "type": "value", "options": { "unexpected": { "text": "Unexpected", "index": 4 } } }
          ]
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 11, "x": 13, "y": 7 },
      "id": 11,
      "options": {
        "barRadius": 0.05,
        "barWidth": 0.6,
        "fullHighlight": false,
        "groupWidth": 0.7,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "orientation": "horizontal",
        "showValue": "always",
        "stacking": "none",
        "tooltip": { "mode": "single", "sort": "desc" },
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 0
      },
      "title": "Errors by Exception Kind",
      "description": "validation = bad input. business_rule = policy violation. downstream_error = external partner failed. unexpected = needs dev investigation.",
      "type": "barchart",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sort_desc(sum by (exception_kind) (increase(external_billpay_errors_total{application=\"$application\",error_code=~\"$error_code\",outcome=~\"$outcome\"}[$__range])))",
          "legendFormat": "{{exception_kind}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "application": true, "job": true, "instance": true, "error_code": true, "outcome": true },
            "renameByName": { "exception_kind": "Exception Kind", "Value": "Count" }
          }
        },
        {
          "id": "sortBy",
          "options": { "fields": [{ "desc": true, "displayName": "Count" }] }
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 102,
      "title": "Is it getting better or worse?",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "Error Count",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 70,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 4,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "none",
          "noValue": "0",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 18 },
      "id": 20,
      "options": {
        "legend": {
          "calcs": ["sum"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Error Count Over Time — by Error Code",
      "description": "Each bar shows how many errors occurred per interval. Stacked so you can see total volume and which codes are contributing most.",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (error_code) (increase(external_billpay_errors_total{application=\"$application\",exception_kind=~\"$exception_kind\",outcome=~\"$outcome\"}[$__interval]))",
          "legendFormat": "{{error_code}}",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "id": 103,
      "title": "Full Detail — every error code × exception kind",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "left",
            "cellOptions": { "type": "auto" },
            "inspect": false,
            "minWidth": 100
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          },
          "noValue": "0"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Error Code" },
            "properties": [
              { "id": "custom.width", "value": 320 },
              { "id": "custom.cellOptions", "value": { "type": "auto" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Exception Kind" },
            "properties": [
              { "id": "custom.width", "value": 200 },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "validation": { "text": "🔷 Validation", "index": 0 } } },
                  { "type": "value", "options": { "business_rule": { "text": "📋 Business Rule", "index": 1 } } },
                  { "type": "value", "options": { "downstream_error": { "text": "🔻 Downstream Error", "index": 2 } } },
                  { "type": "value", "options": { "not_found": { "text": "🔍 Not Found", "index": 3 } } },
                  { "type": "value", "options": { "unexpected": { "text": "🔴 Unexpected", "index": 4 } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Outcome" },
            "properties": [
              { "id": "custom.width", "value": 160 },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "client_error": { "text": "Client Error", "index": 0, "color": "orange" } } },
                  { "type": "value", "options": { "server_error": { "text": "⚠️ Server Error", "index": 1, "color": "red" } } }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Count" },
            "properties": [
              { "id": "custom.width", "value": 140 },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "custom.align", "value": "center" }
            ]
          }
        ]
      },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 29 },
      "id": 30,
      "options": {
        "cellHeight": "md",
        "footer": {
          "countRows": false,
          "enablePagination": true,
          "fields": ["Count"],
          "reducer": ["sum"],
          "show": true
        },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Count" }]
      },
      "title": "Error Breakdown Table",
      "description": "Every combination of error code, exception kind, and outcome. Sort any column. Use filters above to narrow down.",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (error_code, exception_kind, outcome) (increase(external_billpay_errors_total{application=\"$application\",error_code=~\"$error_code\",exception_kind=~\"$exception_kind\",outcome=~\"$outcome\"}[$__range]))",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "application": true, "job": true, "instance": true },
            "renameByName": {
              "error_code": "Error Code",
              "exception_kind": "Exception Kind",
              "outcome": "Outcome",
              "Value": "Count"
            }
          }
        },
        {
          "id": "sortBy",
          "options": { "fields": [{ "desc": true, "displayName": "Count" }] }
        }
      ]
    }

  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "tags": ["billpay", "payments", "errors"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(external_billpay_errors_total, application)",
        "hide": 0,
        "includeAll": false,
        "label": "Application",
        "multi": false,
        "name": "application",
        "options": [],
        "query": {
          "query": "label_values(external_billpay_errors_total, application)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(external_billpay_errors_total{application=\"$application\"}, error_code)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "label": "Error Code",
        "multi": true,
        "name": "error_code",
        "options": [],
        "query": {
          "query": "label_values(external_billpay_errors_total{application=\"$application\"}, error_code)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(external_billpay_errors_total{application=\"$application\"}, exception_kind)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "label": "Exception Kind",
        "multi": true,
        "name": "exception_kind",
        "options": [],
        "query": {
          "query": "label_values(external_billpay_errors_total{application=\"$application\"}, exception_kind)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(external_billpay_errors_total{application=\"$application\"}, outcome)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "label": "Outcome",
        "multi": true,
        "name": "outcome",
        "options": [
          { "selected": true, "text": "All", "value": "$__all" },
          { "selected": false, "text": "client_error", "value": "client_error" },
          { "selected": false, "text": "server_error", "value": "server_error" }
        ],
        "query": {
          "query": "label_values(external_billpay_errors_total{application=\"$application\"}, outcome)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Bill Pay — Error Monitor",
  "uid": "ext-billpay-errors-v2",
  "version": 1,
  "weekStart": ""
}
